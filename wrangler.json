{
	"name": "mcp-admin",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "USERS_KV",
			"id": "REPLACE_WITH_USERS_KV_NAMESPACE_ID"
		}
	],
	"r2_buckets": [
		{
			"binding": "AUDIT_LOGS",
			"bucket_name": "REPLACE_WITH_AUDIT_LOGS_BUCKET_NAME"
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
