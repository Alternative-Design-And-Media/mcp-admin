{
	"name": "mcp-admin",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DATABASE",
			"database_name": "adam-mcp",
			"database_id": "1e5000a0-111b-42ef-a1c0-cf1e51726748"
		}
	],
	"r2_buckets": [
		{
			"binding": "AUDIT_LOGS",
			"bucket_name": "adam-mcp-audit-log"
		},
		{
			"binding": "HANDOVERS",
			"bucket_name": "adam-mcp-handovers"
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
