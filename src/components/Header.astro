---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
---

<header>
<nav>
<h2><a href="/">{SITE_TITLE}</a></h2>
<div class="internal-links">
<HeaderLink href="/">Dashboard</HeaderLink>
<HeaderLink href="/users">Felhasználók</HeaderLink>
<HeaderLink href="/tools">Toolok</HeaderLink>
<HeaderLink href="/logs">Audit logok</HeaderLink>
<HeaderLink href="/handovers">Handoverek</HeaderLink>
</div>
<form action="/logout" method="post">
<button type="submit">Kijelentkezés</button>
</form>
</nav>
</header>
<style>
header {
margin: 0;
padding: 0 1em;
background: white;
box-shadow: 0 2px 8px rgba(var(--black), 5%);
}

h2 {
margin: 0;
font-size: 1em;
}

h2 a,
h2 a.active {
text-decoration: none;
}

nav {
display: flex;
align-items: center;
justify-content: space-between;
gap: 1rem;
}

nav a {
padding: 1em 0.5em;
color: var(--black);
border-bottom: 4px solid transparent;
text-decoration: none;
}

nav a.active {
text-decoration: none;
border-bottom-color: var(--accent);
}

.internal-links {
display: flex;
flex-wrap: wrap;
align-items: center;
gap: 0.5rem;
}

button {
border: 1px solid rgb(var(--gray-light));
background: white;
padding: 0.4rem 0.7rem;
border-radius: 0.35rem;
cursor: pointer;
}

@media (max-width: 860px) {
nav {
flex-wrap: wrap;
padding-bottom: 0.75rem;
}
}
</style>
