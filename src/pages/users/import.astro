---
import AdminLayout from "../../components/AdminLayout.astro";
import { upsertUser, getUserByEmail, grantScopePermission } from "../../utils/users";
import { listAllScopes } from "../../utils/tools";

const db: D1Database = Astro.locals.runtime.env.DATABASE;

type ImportResult = {
  processed:  number;
  newUsers:   string[];
  grants:     { email: string; scopes: string[] }[];
  skipped:    string[];
  errors:     string[];
};

let result: ImportResult | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const file = form.get("user_scopes") as File | null;
  const mode = (form.get("mode") as string | null) ?? "additive";

  const res: ImportResult = { processed: 0, newUsers: [], grants: [], skipped: [], errors: [] };

  if (!file || file.size === 0) {
    res.errors.push("Kérlek töltsd fel a user-scopes.json fájlt.");
    result = res;
  } else {
    try {
      const raw = JSON.parse(await file.text());

      if (typeof raw !== "object" || raw === null || !Array.isArray(raw.users)) {
        throw new Error("Hibás formátum: hiányzik a 'users' tömb.");
      }

      // Build scope name → id map from DB
      const allScopes = await listAllScopes(db);
      const scopeMap = new Map<string, number>(allScopes.map((s) => [s.name, s.id]));

      // Replace mode: wipe all scope permissions first
      if (mode === "replace") {
        await db.prepare("DELETE FROM user_scope_permissions").run();
      }

      for (const entry of raw.users as unknown[]) {
        if (typeof entry !== "object" || entry === null) continue;
        const { email, scopes } = entry as { email?: unknown; scopes?: unknown };

        if (typeof email !== "string" || !email.trim()) {
          res.skipped.push("(üres email)");
          continue;
        }

        const normalizedEmail = email.trim().toLowerCase();

        // Upsert user
        const isNew = !(await getUserByEmail(db, normalizedEmail));
        await upsertUser(db, normalizedEmail);
        if (isNew) res.newUsers.push(normalizedEmail);

        // Resolve scope names to IDs
        let scopeIds: number[];
        if (scopes === "*") {
          scopeIds = allScopes.map((s) => s.id);
        } else if (Array.isArray(scopes)) {
          scopeIds = [];
          for (const s of scopes) {
            if (typeof s !== "string") continue;
            const id = scopeMap.get(s);
            if (id === undefined) {
              res.errors.push(`${normalizedEmail}: ismeretlen scope: '${s}'`);
            } else {
              scopeIds.push(id);
            }
          }
        } else {
          res.skipped.push(`${normalizedEmail}: érvénytelen scopes formátum`);
          continue;
        }

        const user = await getUserByEmail(db, normalizedEmail);
        if (!user) {
          res.errors.push(`${normalizedEmail}: nem sikerült létrehozni`);
          continue;
        }

        const grantedScopes: string[] = [];
        for (const scopeId of scopeIds) {
          await grantScopePermission(db, user.id, scopeId);
          const scopeName = allScopes.find((s) => s.id === scopeId)?.name ?? String(scopeId);
          grantedScopes.push(scopeName);
        }

        if (grantedScopes.length > 0) {
          res.grants.push({ email: normalizedEmail, scopes: grantedScopes });
        }
        res.processed++;
      }
    } catch (e) {
      res.errors.push(`Parse hiba: ${e instanceof Error ? e.message : String(e)}`);
    }

    result = res;
  }
}
---

<AdminLayout title="Felhasználó import">
  <p><a href="/users">&larr; Vissza a felhasználókhoz</a></p>
  <h1>Felhasználó import</h1>

  <p class="info">
    Töltsd fel az <code>adam-mcp/config/user-scopes.json</code> fájlt.
    Az importáló létrehozza a hiányzó felhasználókat és beállítja a scope jogosultságokat.
  </p>

  {result && (
    <div class={`result-box ${result.errors.length > 0 ? "has-error" : "ok"}`}>
      <h2>Import eredménye</h2>

      {result.errors.length > 0 && (
        <div class="section error">
          <strong>Hibák ({result.errors.length}):</strong>
          <ul>{result.errors.map((e) => <li>{e}</li>)}</ul>
        </div>
      )}

      {result.newUsers.length > 0 && (
        <div class="section warn">
          <strong>Új felhasználók ({result.newUsers.length}):</strong>
          <ul>{result.newUsers.map((e) => <li>{e}</li>)}</ul>
        </div>
      )}

      {result.skipped.length > 0 && (
        <div class="section warn">
          <strong>Kihagyva ({result.skipped.length}):</strong>
          <ul>{result.skipped.map((s) => <li>{s}</li>)}</ul>
        </div>
      )}

      {result.grants.length > 0 && (
        <div class="section success">
          <strong>Feldolgozott felhasználók ({result.processed}):</strong>
          <table class="grant-table">
            <thead>
              <tr><th>Email</th><th>Megadott scope-ok</th></tr>
            </thead>
            <tbody>
              {result.grants.map((g) => (
                <tr>
                  <td><a href={`/users/${encodeURIComponent(g.email)}`}>{g.email}</a></td>
                  <td>{g.scopes.join(", ")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {result.errors.length === 0 && result.grants.length === 0 && result.skipped.length === 0 && (
        <p>Nem történt változás.</p>
      )}
    </div>
  )}

  <form method="post" enctype="multipart/form-data" class="import-form">
    <div class="field">
      <label for="user_scopes">user-scopes.json <span class="req">*</span></label>
      <input id="user_scopes" name="user_scopes" type="file" accept=".json,application/json" required />
      <span class="hint">adam-mcp/config/user-scopes.json</span>
    </div>

    <div class="field">
      <label>Import mód</label>
      <div class="radio-group">
        <label class="radio">
          <input type="radio" name="mode" value="additive" checked />
          <span><strong>Additív</strong> – csak új jogosultságokat ad hozzá, a meglévőket nem érinti</span>
        </label>
        <label class="radio">
          <input type="radio" name="mode" value="replace" />
          <span><strong>Csere</strong> – előbb törli az összes scope jogosultságot, majd újra feltölti</span>
        </label>
      </div>
    </div>

    <button type="submit" class="btn-primary">Import indítása</button>
  </form>
</AdminLayout>

<style>
  h1 { margin: 0.5rem 0 1rem; }
  .info {
    font-size: 0.875rem;
    color: #555;
    max-width: 64ch;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  code {
    background: #f0f0f0;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
    font-family: monospace;
  }
  .result-box {
    border: 1px solid #ccc;
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
    background: #fafafa;
  }
  .result-box.ok        { border-color: #a8d5b5; background: #f4fbf6; }
  .result-box.has-error { border-color: #f5c6c6; background: #fff8f8; }
  .result-box h2 { margin: 0 0 0.75rem; font-size: 1rem; }
  .section { margin-bottom: 0.85rem; font-size: 0.875rem; }
  .section ul { margin: 0.3rem 0 0 1.25rem; }
  .section.error   strong { color: #b71c1c; }
  .section.warn    strong { color: #7a5c00; }
  .section.success strong { color: #1e7e34; }
  .grant-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.5rem;
    font-size: 0.8rem;
  }
  .grant-table th,
  .grant-table td {
    border: 1px solid #ddd;
    padding: 0.35rem 0.65rem;
    text-align: left;
    vertical-align: top;
  }
  .grant-table th { background: #f0f0f0; font-weight: 600; }
  .import-form { display: grid; gap: 1.25rem; max-width: 36rem; }
  .field { display: grid; gap: 0.3rem; }
  .field > label { font-size: 0.875rem; font-weight: 600; color: #333; }
  .req { color: #b71c1c; margin-left: 0.15rem; }
  input[type="file"] { font: inherit; font-size: 0.875rem; padding: 0.3rem 0; cursor: pointer; }
  .hint { font-size: 0.78rem; color: #888; font-style: italic; }
  .radio-group { display: grid; gap: 0.5rem; margin-top: 0.1rem; }
  .radio {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-weight: normal;
    font-size: 0.875rem;
    cursor: pointer;
    color: #333;
  }
  .radio input { margin-top: 0.2rem; flex-shrink: 0; }
  .btn-primary {
    font: inherit;
    padding: 0.45rem 1.25rem;
    background: #01696f;
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    justify-self: start;
  }
  .btn-primary:hover { background: #0c4e54; }
</style>
