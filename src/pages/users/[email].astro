---
import AdminLayout from "../../components/AdminLayout.astro";

const { email } = Astro.params;
---

<AdminLayout title="Felhasználó részletek" description="Felhasználó részletes adatai">
	<div class="mock-banner">
		<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<circle cx="12" cy="12" r="10"/>
			<line x1="12" y1="8" x2="12" y2="12"/>
			<line x1="12" y1="16" x2="12.01" y2="16"/>
		</svg>
		<span>Ez az oldal fejlesztés alatt áll. Az olvasás és szerkesztés funkciók hamarosan elérhetők lesznek.</span>
	</div>

	<p><a href="/users">&larr; Vissza a listához</a></p>
	<h1>{email ?? "Felhasználó"}</h1>
	<p class="mock-note">Az adatok betöltése még nem érhető el.</p>
</AdminLayout>

<style>
	.mock-banner {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: #fff8e1;
		border: 1px solid #f9a825;
		border-radius: 0.5rem;
		padding: 0.75rem 1rem;
		margin-bottom: 1.5rem;
		color: #7a5c00;
		font-size: 0.9rem;
	}

	.mock-banner svg {
		flex-shrink: 0;
		color: #f9a825;
	}

	h1 {
		margin: 0.75rem 0 0.5rem;
	}

	.mock-note {
		color: #999;
		font-style: italic;
	}
</style>
