---
import AdminLayout from "../../components/AdminLayout.astro";
import { listAllUsers } from "../../utils/users";

const db: D1Database = Astro.locals.runtime.env.DATABASE;
const users = await listAllUsers(db);
---

<AdminLayout title="Felhasználók" description="Felhasználók és jogosultságok kezelése">
	<div class="page-header">
		<h1>Felhasználók</h1>
	</div>

	<div class="table-wrap">
		<table>
			<thead>
				<tr>
					<th>Email</th>
					<th>Név</th>
					<th>Utolsó bejelentkezés</th>
					<th>Státusz</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				{users.length === 0 ? (
					<tr>
						<td colspan="5" class="empty">Nincs felhasználó az adatbázisban.</td>
					</tr>
				) : (
					users.map((user) => (
						<tr>
							<td>{user.email}</td>
							<td>{user.display_name ?? "–"}</td>
							<td>{user.last_login ?? "–"}</td>
							<td>
								<span class={`badge ${user.is_active ? "active" : "disabled"}`}>
									{user.is_active ? "Aktív" : "Letiltott"}
								</span>
							</td>
							<td><a href={`/users/${encodeURIComponent(user.email)}`}>Részletek</a></td>
						</tr>
					))
				)}
			</tbody>
		</table>
	</div>
</AdminLayout>

<style>
	.page-header {
		margin-bottom: 1.5rem;
	}

	.table-wrap {
		overflow-x: auto;
	}

	table {
		border-collapse: collapse;
		width: 100%;
		font-size: 0.875rem;
	}

	th, td {
		border: 1px solid #ddd;
		padding: 0.5rem 0.75rem;
		text-align: left;
	}

	th {
		background: #f5f5f5;
		font-weight: 600;
	}

	.empty {
		color: #999;
		text-align: center;
		padding: 2rem;
	}

	.badge {
		display: inline-block;
		padding: 0.2rem 0.5rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 500;
	}

	.badge.active {
		background: #e6f4ea;
		color: #1e7e34;
	}

	.badge.disabled {
		background: #fce8e6;
		color: #b71c1c;
	}
</style>
