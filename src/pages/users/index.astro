---
import AdminLayout from "../../components/AdminLayout.astro";
import { listAllUsers, createUser, getUserIdFromEmail } from "../../utils/users";

const db: D1Database = Astro.locals.runtime.env.DATABASE;

let formError = "";
let formSuccess = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = (form.get("email") as string ?? "").trim().toLowerCase();
  const displayName = (form.get("display_name") as string ?? "").trim();

  if (!email || !email.includes("@")) {
    formError = "Érvényes email címet adj meg.";
  } else {
    const result = await createUser(db, email, displayName || null);
    if (result.success) {
      formSuccess = `${getUserIdFromEmail(email)} sikeresen létrehozva.`;
    } else {
      formError = result.error ?? "Hiba történt.";
    }
  }
}

const users = await listAllUsers(db);
---

<AdminLayout title="Felhasználók" description="Felhasználók és jogosultságok kezelése">
	<div class="page-header">
		<h1>Felhasználók</h1>
		<button class="btn-primary" id="toggle-form">+ Új felhasználó</button>
	</div>

	<div class="create-form" id="create-form" hidden>
		<h2>Új felhasználó hozzáadása</h2>
		{formError && <p class="msg error">{formError}</p>}
		{formSuccess && <p class="msg success">{formSuccess}</p>}
		<form method="post">
			<div class="field">
				<label for="email">Email cím <span class="required">*</span></label>
				<input
					id="email"
					name="email"
					type="email"
					required
					placeholder="nev@adamgroup.hu"
					autocomplete="off"
				/>
			</div>
			<div class="field">
				<label for="display_name">Név <span class="optional">(opcionális)</span></label>
				<input
					id="display_name"
					name="display_name"
					type="text"
					placeholder="Pl. Kiss János"
				/>
			</div>
			<div class="form-actions">
				<button type="submit" class="btn-primary">Létrehozás</button>
				<button type="button" class="btn-ghost" id="cancel-form">Mégse</button>
			</div>
		</form>
	</div>

	<div class="table-wrap">
		<table>
			<thead>
				<tr>
					<th>Azonosító</th>
					<th>Email</th>
					<th>Név</th>
					<th>Utolsó bejelentkezés</th>
					<th>Státusz</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				{users.length === 0 ? (
					<tr>
						<td colspan="6" class="empty">Nincs felhasználó az adatbázisban.</td>
					</tr>
				) : (
					users.map((user) => (
						<tr>
							<td><code>{getUserIdFromEmail(user.email)}</code></td>
							<td>{user.email}</td>
							<td>{user.display_name ?? "–"}</td>
							<td>{user.last_login ?? "–"}</td>
							<td>
								<span class={`badge ${user.is_active ? "active" : "disabled"}`}>
									{user.is_active ? "Aktív" : "Letiltott"}
								</span>
							</td>
							<td><a href={`/users/${encodeURIComponent(user.email)}`}>Részletek</a></td>
						</tr>
					))
				)}
			</tbody>
		</table>
	</div>
</AdminLayout>

<script>
  const toggleBtn = document.getElementById("toggle-form");
  const cancelBtn = document.getElementById("cancel-form");
  const form = document.getElementById("create-form");

  toggleBtn?.addEventListener("click", () => {
    form?.removeAttribute("hidden");
    toggleBtn.setAttribute("hidden", "");
  });

  cancelBtn?.addEventListener("click", () => {
    form?.setAttribute("hidden", "");
    toggleBtn?.removeAttribute("hidden");
  });
</script>

<style>
	.page-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
	}

	.create-form {
		background: #f9f9f9;
		border: 1px solid #ddd;
		border-radius: 0.5rem;
		padding: 1.25rem 1.5rem;
		margin-bottom: 1.5rem;
	}

	.create-form h2 {
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.field {
		display: grid;
		gap: 0.35rem;
		margin-bottom: 0.85rem;
	}

	label {
		font-size: 0.875rem;
		font-weight: 500;
	}

	.required { color: #b71c1c; }
	.optional { color: #999; font-weight: 400; font-size: 0.8rem; }

	input[type="email"],
	input[type="text"] {
		font: inherit;
		padding: 0.45rem 0.65rem;
		border: 1px solid #ccc;
		border-radius: 0.375rem;
		width: 100%;
		max-width: 28rem;
	}

	input:focus {
		outline: 2px solid #01696f;
		outline-offset: 2px;
		border-color: #01696f;
	}

	.form-actions {
		display: flex;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.msg {
		padding: 0.5rem 0.75rem;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		margin-bottom: 0.75rem;
	}
	.msg.success { background: #e6f4ea; color: #1e7e34; }
	.msg.error   { background: #fce8e6; color: #b71c1c; }

	.table-wrap { overflow-x: auto; }

	table {
		border-collapse: collapse;
		width: 100%;
		font-size: 0.875rem;
	}

	th, td {
		border: 1px solid #ddd;
		padding: 0.5rem 0.75rem;
		text-align: left;
	}

	th { background: #f5f5f5; font-weight: 600; }

	.empty { color: #999; text-align: center; padding: 2rem; }

	code {
		background: #f0f0f0;
		padding: 0.1rem 0.4rem;
		border-radius: 0.25rem;
		font-size: 0.8rem;
	}

	.badge {
		display: inline-block;
		padding: 0.2rem 0.5rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 500;
	}
	.badge.active   { background: #e6f4ea; color: #1e7e34; }
	.badge.disabled { background: #fce8e6; color: #b71c1c; }

	.btn-primary {
		font: inherit;
		padding: 0.4rem 1rem;
		border-radius: 0.375rem;
		border: none;
		cursor: pointer;
		background: #01696f;
		color: #fff;
		font-size: 0.875rem;
	}
	.btn-primary:hover { background: #0c4e54; }

	.btn-ghost {
		font: inherit;
		padding: 0.4rem 1rem;
		border-radius: 0.375rem;
		border: 1px solid #ccc;
		cursor: pointer;
		background: transparent;
		font-size: 0.875rem;
	}
	.btn-ghost:hover { background: #f0f0f0; }
</style>
