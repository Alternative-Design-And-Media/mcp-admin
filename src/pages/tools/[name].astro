---
import AdminLayout from "../../components/AdminLayout.astro";
import { fetchToolsFromMcp } from "../../utils/tools";

const env = Astro.locals.runtime.env;
const encodedName = Astro.params.name ?? "";
let toolName = "";

try {
	toolName = decodeURIComponent(encodedName);
} catch {
	return Astro.redirect("/tools");
}

const tools = await fetchToolsFromMcp(env);
const tool = tools.find((candidate) => candidate.name === toolName);

if (!tool) {
	return Astro.redirect("/tools");
}
---

<AdminLayout title={`Tool: ${toolName}`} description="Tool részletek">
	<p><a href="/tools">&larr; Vissza a tool listához</a></p>
	<h1>{toolName}</h1>

	<section>
		<h2>Leírás</h2>
		<p>{tool.description || "Nincs leírás."}</p>
	</section>

	<section>
		<h2>Input séma</h2>
		<pre><code>{JSON.stringify(tool.inputSchema, null, 2)}</code></pre>
	</section>

	<section>
		<div class="mock-banner">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<circle cx="12" cy="12" r="10"/>
				<line x1="12" y1="8" x2="12" y2="12"/>
				<line x1="12" y1="16" x2="12.01" y2="16"/>
			</svg>
			<span>Az engedélyezett felhasználók kezelése fejlesztés alatt áll.</span>
		</div>
	</section>
</AdminLayout>

<style>
	pre {
		overflow: auto;
		max-height: 24rem;
		background: #f5f5f5;
		padding: 1rem;
		border-radius: 0.5rem;
		font-size: 0.85rem;
	}

	.mock-banner {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: #fff8e1;
		border: 1px solid #f9a825;
		border-radius: 0.5rem;
		padding: 0.75rem 1rem;
		color: #7a5c00;
		font-size: 0.9rem;
	}

	.mock-banner svg {
		flex-shrink: 0;
		color: #f9a825;
	}
</style>
