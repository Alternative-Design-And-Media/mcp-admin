---
import AdminLayout from "../../components/AdminLayout.astro";
import { listAllTools } from "../../utils/tools";
import { listAllUsers } from "../../utils/users";

const db: D1Database = Astro.locals.runtime.env.DATABASE;
const encodedName = Astro.params.name ?? "";
let toolName = "";

try {
  toolName = decodeURIComponent(encodedName);
} catch {
  return Astro.redirect("/tools");
}

const [allTools, allUsers] = await Promise.all([
  listAllTools(db),
  listAllUsers(db),
]);

const tool = allTools.find((t) => t.name === toolName);
if (!tool) return Astro.redirect("/tools");

// Users who have the scope this tool requires
const usersWithScope = await db
  .prepare(
    `SELECT u.email, u.display_name, u.is_active, usp.granted_at
     FROM user_scope_permissions usp
     JOIN users u ON u.id = usp.user_id
     WHERE usp.scope_id = ?
     ORDER BY u.email ASC`
  )
  .bind(tool.scope_id)
  .all<{ email: string; display_name: string | null; is_active: number; granted_at: string }>();

const grantedEmails = new Set(usersWithScope.results.map((u) => u.email));
const usersWithout = allUsers.filter((u) => u.is_active && !grantedEmails.has(u.email));
---

<AdminLayout title={`Tool: ${toolName}`}>
  <p><a href="/tools">&larr; Vissza a tool listához</a></p>
  <h1>{toolName}</h1>

  <section class="card">
    <h2>Scope</h2>
    <p>
      Ez a tool a <code>{tool.scope_name}</code> scope-ot igényli.
      A jogosultságok scope szinten kezelhetők a
      <a href={`/users`}>felhasználók oldalán</a>.
    </p>
  </section>

  <section class="card">
    <h2>Felhasználók ezzel a scope-pal ({usersWithScope.results.length})</h2>

    {usersWithScope.results.length === 0 ? (
      <p class="empty">Még egyetlen felhasználónak sincs meg ez a scope.</p>
    ) : (
      <table class="perm-table">
        <thead>
          <tr>
            <th>Email</th>
            <th>Megjelenített név</th>
            <th>Státusz</th>
            <th>Megadva</th>
          </tr>
        </thead>
        <tbody>
          {usersWithScope.results.map((u) => (
            <tr>
              <td><a href={`/users/${encodeURIComponent(u.email)}`}>{u.email}</a></td>
              <td>{u.display_name ?? "–"}</td>
              <td class={u.is_active ? "active" : "inactive"}>
                {u.is_active ? "Aktív" : "Letiltva"}
              </td>
              <td class="muted">{u.granted_at}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}

    {usersWithout.length > 0 && (
      <p class="hint">
        {usersWithout.length} aktív felhasználónak nincs meg a <code>{tool.scope_name}</code> scope.
        <a href="/users">Jogosultság kezelése →</a>
      </p>
    )}
  </section>
</AdminLayout>

<style>
  h1 { margin: 0.5rem 0 1.25rem; }
  section { margin-bottom: 2rem; }
  h2 {
    margin-bottom: 0.75rem;
    font-size: 1rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.4rem;
  }
  code {
    background: #f0f0f0;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
    font-family: monospace;
  }
  .perm-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .perm-table th,
  .perm-table td {
    border: 1px solid #e0e0e0;
    padding: 0.45rem 0.75rem;
    text-align: left;
  }
  .perm-table th { background: #f5f5f5; font-weight: 600; }
  .muted  { color: #888; font-size: 0.8rem; }
  .active   { color: #1e7e34; }
  .inactive { color: #b71c1c; }
  .empty { color: #999; font-style: italic; font-size: 0.875rem; }
  .hint  { font-size: 0.8rem; color: #666; margin-top: 0.75rem; }
</style>
