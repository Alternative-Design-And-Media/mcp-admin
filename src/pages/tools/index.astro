---
import AdminLayout from "../../components/AdminLayout.astro";
import { fetchToolsFromMcp } from "../../utils/tools";

const env = Astro.locals.runtime.env;
const query = Astro.url.searchParams;
const search = query.get("q")?.trim().toLowerCase() ?? "";

const tools = await fetchToolsFromMcp(env);
const filteredTools = tools.filter((tool) => tool.name.toLowerCase().includes(search));
---

<AdminLayout title="Toolok" description="MCP toolok áttekintése">
	<h1>MCP Toolok</h1>

	<form method="get" class="filter-form">
		<label for="q">Tool név keresés</label>
		<input id="q" name="q" type="search" value={query.get("q") ?? ""} placeholder="pl. tools/list" />
		<button type="submit">Keresés</button>
	</form>

	<table>
		<thead>
			<tr>
				<th>Név</th>
				<th>Leírás</th>
			</tr>
		</thead>
		<tbody>
			{filteredTools.length === 0 ? (
				<tr>
					<td colspan="2">Nincs megjeleníthető tool. Ellenőrizd a MCP_SERVER_URL beállítást.</td>
				</tr>
			) : (
				filteredTools.map((tool) => (
					<tr>
						<td><a href={`/tools/${encodeURIComponent(tool.name)}`}>{tool.name}</a></td>
						<td>{tool.description || "-"}</td>
					</tr>
				))
			)}
		</tbody>
	</table>
</AdminLayout>

<style>
	.filter-form {
		display: grid;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	label {
		display: grid;
		gap: 0.35rem;
	}

	input, button {
		font: inherit;
		padding: 0.5rem;
	}

	table {
		border-collapse: collapse;
		width: 100%;
	}

	th, td {
		border: 1px solid #ddd;
		padding: 0.5rem;
		vertical-align: top;
	}
</style>
