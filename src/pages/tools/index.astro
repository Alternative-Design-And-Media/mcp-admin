---
import AdminLayout from "../../components/AdminLayout.astro";
import { listAllTools } from "../../utils/tools";

const db: D1Database = Astro.locals.runtime.env.DATABASE;
const query = Astro.url.searchParams;
const search = query.get("q")?.trim().toLowerCase() ?? "";

const allTools = await listAllTools(db);
const filteredTools = allTools.filter((t) => t.name.toLowerCase().includes(search));
---

<AdminLayout title="Toolok" description="MCP toolok áttekintése">
	<h1>MCP Toolok</h1>

	<form method="get" class="filter-form">
		<label for="q">Tool név keresés</label>
		<input id="q" name="q" type="search" value={query.get("q") ?? ""} placeholder="pl. rentman_projects_list" />
		<button type="submit">Keresés</button>
	</form>

	<table>
		<thead>
			<tr>
				<th>Név</th>
				<th>Scope</th>
				<th>Leírás</th>
			</tr>
		</thead>
		<tbody>
			{filteredTools.length === 0 ? (
				<tr>
					<td colspan="3">Nincs megjeleníthető tool. Ellenőrizd a tools táblát a D1-ben.</td>
				</tr>
			) : (
				filteredTools.map((t) => (
					<tr>
						<td><a href={`/tools/${encodeURIComponent(t.name)}`}>{t.name}</a></td>
						<td><code>{t.scope_name ?? "–"}</code></td>
						<td>{t.description || "–"}</td>
					</tr>
				))
			)}
		</tbody>
	</table>
</AdminLayout>

<style>
	.filter-form {
		display: flex;
		gap: 0.5rem;
		align-items: flex-end;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}
	.filter-form label {
		display: grid;
		gap: 0.25rem;
		font-size: 0.875rem;
		font-weight: 500;
	}
	input, button { font: inherit; padding: 0.4rem 0.6rem; }
	input { border: 1px solid #ccc; border-radius: 0.375rem; min-width: 220px; }
	button { background: #01696f; color: #fff; border: none; border-radius: 0.375rem; cursor: pointer; }
	button:hover { background: #0c4e54; }
	table { border-collapse: collapse; width: 100%; }
	th, td { border: 1px solid #ddd; padding: 0.5rem 0.75rem; vertical-align: top; font-size: 0.875rem; }
	th { background: #f5f5f5; font-weight: 600; }
	code { background: #f0f0f0; padding: 0.1rem 0.35rem; border-radius: 0.25rem; font-size: 0.8em; }
</style>
