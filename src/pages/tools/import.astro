---
import AdminLayout from "../../components/AdminLayout.astro";
import { grantToolPermission, listAllUsers, upsertUser } from "../../utils/users";

const db: D1Database = Astro.locals.runtime.env.DATABASE;

type ImportResult = {
  processed: number;
  skipped: string[];
  grants: { email: string; tools: string[] }[];
  errors: string[];
  newUsers: string[];
};

let result: ImportResult | null = null;

// ── helpers ────────────────────────────────────────────────────────────────

function resolveToolNames(
  userScopes: string[] | "*",
  toolScopes: Record<string, string>,
  allToolNames: string[]
): string[] {
  if (userScopes === "*") return allToolNames;
  const scopeSet = new Set(userScopes);
  return allToolNames.filter((t) => {
    const scope = toolScopes[t];
    return scope !== undefined && scopeSet.has(scope);
  });
}

async function parseJson(file: File): Promise<unknown> {
  const text = await file.text();
  return JSON.parse(text);
}

// ── POST handler ───────────────────────────────────────────────────────────

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const userFile = form.get("user_scopes") as File | null;
  const toolFile = form.get("tool_scopes") as File | null;
  const mode = (form.get("mode") as string | null) ?? "additive";

  const res: ImportResult = { processed: 0, skipped: [], grants: [], errors: [], newUsers: [] };

  if (!userFile || !toolFile || userFile.size === 0 || toolFile.size === 0) {
    res.errors.push("Mindkét fájlt meg kell adni (user-scopes.json és tool-scopes.json).");
    result = res;
  } else {
    try {
      const [userRaw, toolRaw] = await Promise.all([parseJson(userFile), parseJson(toolFile)]);

      // Validate tool-scopes: { [toolName]: scopeString }
      if (typeof toolRaw !== "object" || toolRaw === null || Array.isArray(toolRaw)) {
        throw new Error("tool-scopes.json: invalid format (expected object)");
      }
      const toolScopes = toolRaw as Record<string, string>;
      const allToolNames = Object.keys(toolScopes);

      // Validate user-scopes: { users: [{email, scopes}], default_scopes?: [] }
      if (typeof userRaw !== "object" || userRaw === null || Array.isArray(userRaw)) {
        throw new Error("user-scopes.json: invalid format (expected object)");
      }
      const userRoot = userRaw as Record<string, unknown>;
      if (!Array.isArray(userRoot.users)) {
        throw new Error('user-scopes.json: hiányzó \'users\' tömb');
      }

      const existingUsers = await listAllUsers(db);
      const existingEmails = new Set(existingUsers.map((u) => u.email));

      // Replace mode: wipe all existing permissions first
      if (mode === "replace") {
        await db.prepare("DELETE FROM user_tool_permissions").run();
      }

      for (const entry of userRoot.users as unknown[]) {
        if (typeof entry !== "object" || entry === null) continue;
        const { email, scopes } = entry as { email?: unknown; scopes?: unknown };

        if (typeof email !== "string" || !email.trim()) {
          res.skipped.push("(üres email)");
          continue;
        }

        const normalizedEmail = email.trim().toLowerCase();

        // Upsert user if not yet in DB
        if (!existingEmails.has(normalizedEmail)) {
          await upsertUser(db, normalizedEmail);
          res.newUsers.push(normalizedEmail);
          existingEmails.add(normalizedEmail);
        }

        let userScopes: string[] | "*";
        if (scopes === "*") {
          userScopes = "*";
        } else if (Array.isArray(scopes)) {
          userScopes = scopes.filter((s): s is string => typeof s === "string");
        } else {
          res.skipped.push(`${normalizedEmail}: invalid scopes format`);
          continue;
        }

        const toolsToGrant = resolveToolNames(userScopes, toolScopes, allToolNames);

        // Additive mode: skip already-granted tools automatically (ON CONFLICT DO NOTHING)
        let grantedCount = 0;
        for (const toolName of toolsToGrant) {
          try {
            await grantToolPermission(db, normalizedEmail, toolName);
            grantedCount++;
          } catch (e) {
            res.errors.push(`${normalizedEmail} → ${toolName}: ${String(e)}`);
          }
        }

        if (grantedCount > 0) {
          res.grants.push({ email: normalizedEmail, tools: toolsToGrant });
        }
        res.processed++;
      }
    } catch (e) {
      res.errors.push(`Parse hiba: ${e instanceof Error ? e.message : String(e)}`);
    }

    result = res;
  }
}
---

<AdminLayout title="Scope import" description="Ideiglenes tool jogosultság import">
  <p><a href="/tools">&larr; Vissza a tool listához</a></p>

  <div class="header">
    <h1>Scope alapú jogosultság import</h1>
    <span class="badge-tmp">Ideiglenes</span>
  </div>

  <p class="info">
    Töltsd fel az <code>adam-mcp/config</code> könyvtárból a <code>user-scopes.json</code> és
    <code>tool-scopes.json</code> fájlokat. Az importáló feloldja a scope → tool leképezést és
    beírja az engedélyeket a <code>user_tool_permissions</code> táblába.
  </p>

  {result && (
    <div class={`result-box ${result.errors.length > 0 ? "has-error" : "ok"}`}>
      <h2>Import eredménye</h2>

      {result.errors.length > 0 && (
        <div class="section error">
          <strong>Hibák ({result.errors.length}):</strong>
          <ul>{result.errors.map((e) => <li>{e}</li>)}</ul>
        </div>
      )}

      {result.newUsers.length > 0 && (
        <div class="section warn">
          <strong>Új felhasználók létrehozva ({result.newUsers.length}):</strong>
          <ul>{result.newUsers.map((e) => <li>{e}</li>)}</ul>
        </div>
      )}

      {result.skipped.length > 0 && (
        <div class="section warn">
          <strong>Kihagyva ({result.skipped.length}):</strong>
          <ul>{result.skipped.map((s) => <li>{s}</li>)}</ul>
        </div>
      )}

      {result.grants.length > 0 && (
        <div class="section success">
          <strong>Feldolgozott felhasználók ({result.processed}):</strong>
          <table class="grant-table">
            <thead>
              <tr><th>Email</th><th>Megadott toolok</th></tr>
            </thead>
            <tbody>
              {result.grants.map((g) => (
                <tr>
                  <td>{g.email}</td>
                  <td>{g.tools.length} tool ({g.tools.join(", ")})</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {result.errors.length === 0 && result.grants.length === 0 && (
        <p>Nem történt változás (minden jogosultság már megvolt).</p>
      )}
    </div>
  )}

  <form method="post" enctype="multipart/form-data" class="import-form">
    <div class="field">
      <label for="user_scopes">
        <code>user-scopes.json</code>
        <span class="required">*</span>
      </label>
      <input id="user_scopes" name="user_scopes" type="file" accept=".json,application/json" required />
      <span class="hint">adam-mcp/config/user-scopes.json</span>
    </div>

    <div class="field">
      <label for="tool_scopes">
        <code>tool-scopes.json</code>
        <span class="required">*</span>
      </label>
      <input id="tool_scopes" name="tool_scopes" type="file" accept=".json,application/json" required />
      <span class="hint">adam-mcp/config/tool-scopes.json</span>
    </div>

    <div class="field">
      <label>Import mód</label>
      <div class="radio-group">
        <label class="radio">
          <input type="radio" name="mode" value="additive" checked />
          <span>
            <strong>Additív</strong> – csak az új jogosultságokat adja hozzá,
            a meglévőket nem érinti
          </span>
        </label>
        <label class="radio">
          <input type="radio" name="mode" value="replace" />
          <span>
            <strong>Csere</strong> – előbb törli az összes meglévő jogosultságot,
            majd újra feltölti a fájlból
          </span>
        </label>
      </div>
    </div>

    <button type="submit" class="btn-primary">Import indítása</button>
  </form>
</AdminLayout>

<style>
  .header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  h1 { margin: 0; }

  .badge-tmp {
    background: #fff3cd;
    color: #856404;
    border: 1px solid #ffc107;
    border-radius: 9999px;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .info {
    font-size: 0.875rem;
    color: #555;
    margin-bottom: 1.5rem;
    max-width: 64ch;
    line-height: 1.6;
  }

  code {
    background: #f0f0f0;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
    font-family: monospace;
  }

  /* ── Result box ── */
  .result-box {
    border: 1px solid #ccc;
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
    background: #fafafa;
  }
  .result-box.ok    { border-color: #a8d5b5; background: #f4fbf6; }
  .result-box.has-error { border-color: #f5c6c6; background: #fff8f8; }
  .result-box h2 { margin: 0 0 0.75rem; font-size: 1rem; }

  .section { margin-bottom: 0.85rem; font-size: 0.875rem; }
  .section ul { margin: 0.3rem 0 0 1.25rem; }
  .section.error  strong { color: #b71c1c; }
  .section.warn   strong { color: #7a5c00; }
  .section.success strong { color: #1e7e34; }

  .grant-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.5rem;
    font-size: 0.8rem;
  }
  .grant-table th,
  .grant-table td {
    border: 1px solid #ddd;
    padding: 0.35rem 0.65rem;
    text-align: left;
    vertical-align: top;
  }
  .grant-table th { background: #f0f0f0; font-weight: 600; }

  /* ── Form ── */
  .import-form {
    display: grid;
    gap: 1.25rem;
    max-width: 36rem;
  }

  .field {
    display: grid;
    gap: 0.3rem;
  }
  .field > label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #333;
  }
  .required { color: #b71c1c; margin-left: 0.15rem; }

  input[type="file"] {
    font: inherit;
    font-size: 0.875rem;
    padding: 0.3rem 0;
    cursor: pointer;
  }

  .hint {
    font-size: 0.78rem;
    color: #888;
    font-style: italic;
  }

  /* ── Radio ── */
  .radio-group {
    display: grid;
    gap: 0.5rem;
    margin-top: 0.1rem;
  }
  .radio {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-weight: normal !important;
    font-size: 0.875rem;
    cursor: pointer;
    color: #333;
  }
  .radio input { margin-top: 0.2rem; flex-shrink: 0; cursor: pointer; }
  .radio strong { display: inline; font-size: inherit; }

  /* ── Submit ── */
  .btn-primary {
    font: inherit;
    padding: 0.45rem 1.25rem;
    background: #01696f;
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    justify-self: start;
  }
  .btn-primary:hover { background: #0c4e54; }
</style>
