---
import AdminLayout from "../components/AdminLayout.astro";
import {
  getDashboardStats,
  getDailyCallStats,
  getTopTools,
  getTopUsers,
  listAuditLogsD1,
} from "../utils/audit";

const db: D1Database = Astro.locals.runtime.env.DATABASE;

const [
  stats,
  dailyCalls,
  topTools,
  topUsers,
  recentResult,
] = await Promise.all([
  getDashboardStats(db),
  getDailyCallStats(db, 30),
  getTopTools(db, 10),
  getTopUsers(db, 5),
  listAuditLogsD1(db, {}, 1, 8),
]);

// Napi trend: feltöltjük a hiányzó napokat nullával (utolsó 30 nap)
const today = new Date();
const trendDays: { day: string; total: number; denied: number }[] = [];
for (let i = 29; i >= 0; i--) {
  const d = new Date(today);
  d.setUTCDate(d.getUTCDate() - i);
  const dayStr = d.toISOString().slice(0, 10);
  const found = dailyCalls.find((r) => r.day === dayStr);
  trendDays.push({ day: dayStr, total: found?.total ?? 0, denied: found?.denied ?? 0 });
}

// Barchart: max érték a skálázáshoz
const maxDayTotal = Math.max(...trendDays.map((d) => d.total), 1);

// Tiltott arány ma (%)
const deniedPct = stats.todayTotal > 0
  ? Math.round((stats.todayDenied / stats.todayTotal) * 100)
  : 0;

// Időformázó
const TZ = "Europe/Budapest";
function formatTs(utcStr: string): string {
  const d = new Date(utcStr.includes("T") ? utcStr : utcStr.replace(" ", "T") + "Z");
  return d.toLocaleString("hu-HU", {
    timeZone: TZ,
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
  });
}

function formatDay(dayStr: string): string {
  const d = new Date(dayStr + "T00:00:00Z");
  return d.toLocaleDateString("hu-HU", { timeZone: "UTC", month: "short", day: "numeric" });
}
---

<AdminLayout title="MCP Admin Dashboard" description="MCP admin kezdőoldal">

  <!-- ── Fejléc ─────────────────────────────────────────────────────────── -->
  <div class="page-header">
    <h1>Dashboard</h1>
    <span class="updated-at">Frissítve: {new Date().toLocaleString("hu-HU", { timeZone: TZ, hour: "2-digit", minute: "2-digit" })}</span>
  </div>

  <!-- ── KPI sor ────────────────────────────────────────────────────────── -->
  <div class="kpi-row">
    <div class="kpi-card">
      <span class="kpi-label">Mai hívások</span>
      <span class="kpi-value">{stats.todayTotal.toLocaleString("hu-HU")}</span>
    </div>
    <div class="kpi-card kpi-warn">
      <span class="kpi-label">Tiltott ma</span>
      <span class="kpi-value">
        {stats.todayDenied.toLocaleString("hu-HU")}
        {stats.todayTotal > 0 && <span class="kpi-sub">{deniedPct}%</span>}
      </span>
    </div>
    <div class="kpi-card">
      <span class="kpi-label">Aktív userek</span>
      <span class="kpi-value">{stats.activeUsers.toLocaleString("hu-HU")}</span>
    </div>
    <div class="kpi-card">
      <span class="kpi-label">Leghívottabb tool</span>
      <span class="kpi-value kpi-tool">
        {stats.topToolName
          ? <><code>{stats.topToolName}</code><span class="kpi-sub">{stats.topToolCount.toLocaleString("hu-HU")} hívás</span></>
          : <span class="kpi-empty">–</span>
        }
      </span>
    </div>
  </div>

  <!-- ── Napi trend (30 nap) ────────────────────────────────────────────── -->
  <section class="card">
    <div class="card-header">
      <h2>Hívások az elmúlt 30 napban</h2>
    </div>
    <div class="trend-chart">
      {trendDays.map((d) => (
        <div class="trend-col" title={`${formatDay(d.day)}: ${d.total} hívás, ${d.denied} tiltott`}>
          <div class="trend-bar-wrap">
            {d.total > 0 && (
              <div
                class="trend-bar-total"
                style={`height: ${Math.round((d.total / maxDayTotal) * 100)}%`}
              />
            )}
            {d.denied > 0 && (
              <div
                class="trend-bar-denied"
                style={`height: ${Math.round((d.denied / maxDayTotal) * 100)}%`}
              />
            )}
          </div>
          <span class="trend-label">
            {d.day.slice(8)} <!-- nap száma -->
          </span>
        </div>
      ))}
    </div>
    <div class="trend-legend">
      <span class="legend-item legend-total">Összes hívás</span>
      <span class="legend-item legend-denied">Tiltott</span>
    </div>
  </section>

  <!-- ── Alsó két oszlop ────────────────────────────────────────────────── -->
  <div class="two-col">

    <!-- Top tools -->
    <section class="card">
      <div class="card-header">
        <h2>Top 10 tool</h2>
        <a href="/logs" class="card-link">Összes log →</a>
      </div>
      <table class="stat-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Tool</th>
            <th class="num-col">Hívás</th>
            <th class="num-col">Tiltott</th>
          </tr>
        </thead>
        <tbody>
          {topTools.length === 0 ? (
            <tr><td colspan="4" class="empty-row">Nincs adat.</td></tr>
          ) : (
            topTools.map((t, i) => {
              const pct = t.total > 0 ? Math.round((t.denied / t.total) * 100) : 0;
              return (
                <tr>
                  <td class="rank-col">{i + 1}</td>
                  <td class="tool-col"><code>{t.tool_name}</code></td>
                  <td class="num-col">{t.total.toLocaleString("hu-HU")}</td>
                  <td class="num-col">
                    {t.denied > 0
                      ? <span class="denied-count">{t.denied} <span class="denied-pct">({pct}%)</span></span>
                      : <span class="zero">–</span>
                    }
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </section>

    <!-- Jobb oldali panel: Top userek + legutóbbi események -->
    <div class="right-col">

      <!-- Top userek -->
      <section class="card">
        <div class="card-header">
          <h2>Legaktívabb userek</h2>
          <a href="/users" class="card-link">Összes user →</a>
        </div>
        <table class="stat-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Felhasználó</th>
              <th class="num-col">Hívás</th>
              <th class="num-col">Tiltott</th>
            </tr>
          </thead>
          <tbody>
            {topUsers.length === 0 ? (
              <tr><td colspan="4" class="empty-row">Nincs adat.</td></tr>
            ) : (
              topUsers.map((u, i) => (
                <tr>
                  <td class="rank-col">{i + 1}</td>
                  <td class="user-col">
                    <a href={`/users/${encodeURIComponent(u.email)}`}>
                      {u.display_name ?? u.email}
                    </a>
                  </td>
                  <td class="num-col">{u.total.toLocaleString("hu-HU")}</td>
                  <td class="num-col">
                    {u.denied > 0
                      ? <span class="denied-count">{u.denied}</span>
                      : <span class="zero">–</span>
                    }
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </section>

      <!-- Legutóbbi események -->
      <section class="card">
        <div class="card-header">
          <h2>Legutóbbi események</h2>
          <a href="/logs" class="card-link">Összes →</a>
        </div>
        <ul class="event-feed">
          {recentResult.logs.length === 0 ? (
            <li class="empty-row">Nincs esemény.</li>
          ) : (
            recentResult.logs.map((log) => (
              <li class={`event-item ${log.allowed ? "" : "event-denied"}`}>
                <span class={`event-dot ${log.allowed ? "dot-ok" : "dot-deny"}`} />
                <span class="event-body">
                  <span class="event-tool"><code>{log.tool_name}</code></span>
                  <span class="event-user">
                    {log.user_email
                      ? <a href={`/users/${encodeURIComponent(log.user_email)}`}>{log.user_display_name ?? log.user_email}</a>
                      : <span class="muted">ismeretlen</span>
                    }
                  </span>
                </span>
                <time class="event-ts" datetime={log.ts}>{formatTs(log.ts)}</time>
              </li>
            ))
          )}
        </ul>
      </section>

    </div>
  </div>

</AdminLayout>

<style>
  /* ── Alap ────────────────────────────────────────────────────────── */
  .page-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .page-header h1 { margin: 0; font-size: 1.4rem; }
  .updated-at { margin-left: auto; font-size: 0.78rem; color: #999; }

  .card {
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    background: #fff;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid #f0f0f0;
    background: #f9f9f9;
  }
  .card-header h2 { margin: 0; font-size: 0.88rem; font-weight: 700; color: #333; }
  .card-link { font-size: 0.78rem; color: #01696f; text-decoration: none; }
  .card-link:hover { text-decoration: underline; }

  /* ── KPI ─────────────────────────────────────────────────────────── */
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 900px) { .kpi-row { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .kpi-row { grid-template-columns: 1fr; } }

  .kpi-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    padding: 0.9rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .kpi-card.kpi-warn { border-left: 3px solid #e53935; }
  .kpi-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #888; }
  .kpi-value {
    font-size: 1.7rem;
    font-weight: 700;
    color: #1a1a1a;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    line-height: 1.1;
  }
  .kpi-sub { font-size: 0.85rem; font-weight: 500; color: #888; }
  .kpi-tool { font-size: 1rem; align-items: center; flex-wrap: wrap; }
  .kpi-tool code { font-size: 0.82rem; background: #f3f3f3; padding: 0.15rem 0.4rem; border-radius: 0.25rem; }
  .kpi-empty { color: #ccc; }

  /* ── Trend chart ─────────────────────────────────────────────────── */
  .trend-chart {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    padding: 1rem 1rem 0.25rem;
    height: 110px;
    box-sizing: content-box;
  }
  .trend-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    gap: 3px;
    cursor: default;
  }
  .trend-bar-wrap {
    flex: 1;
    width: 100%;
    display: flex;
    align-items: flex-end;
    position: relative;
    min-height: 0;
  }
  .trend-bar-total {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #cedcd8;
    border-radius: 2px 2px 0 0;
    transition: height 0.2s;
  }
  .trend-bar-denied {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #e53935;
    opacity: 0.7;
    border-radius: 2px 2px 0 0;
  }
  .trend-col:hover .trend-bar-total { background: #01696f; }
  .trend-label {
    font-size: 0.62rem;
    color: #bbb;
    line-height: 1;
    padding-bottom: 0.25rem;
    white-space: nowrap;
  }
  .trend-legend {
    display: flex;
    gap: 1.25rem;
    padding: 0.5rem 1rem 0.75rem;
    font-size: 0.75rem;
    color: #888;
  }
  .legend-item { display: flex; align-items: center; gap: 0.35rem; }
  .legend-item::before { content: ""; display: inline-block; width: 10px; height: 10px; border-radius: 2px; }
  .legend-total::before { background: #cedcd8; }
  .legend-denied::before { background: #e53935; opacity: 0.7; }

  /* ── Két oszlopos layout ──────────────────────────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 860px) { .two-col { grid-template-columns: 1fr; } }

  .right-col { display: flex; flex-direction: column; gap: 0; }
  .right-col .card { margin-bottom: 1.25rem; }
  .right-col .card:last-child { margin-bottom: 0; }

  /* ── Stat táblázat ────────────────────────────────────────────────── */
  .stat-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.83rem;
  }
  .stat-table thead tr {
    background: #f5f5f5;
    border-bottom: 1px solid #e8e8e8;
  }
  .stat-table thead th {
    padding: 0.4rem 0.75rem;
    text-align: left;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #888;
  }
  .stat-table tbody tr {
    border-bottom: 1px solid #f3f3f3;
    transition: background 0.1s;
  }
  .stat-table tbody tr:last-child { border-bottom: none; }
  .stat-table tbody tr:hover { background: #fafafa; }
  .stat-table td { padding: 0.4rem 0.75rem; vertical-align: middle; }

  .rank-col { width: 28px; color: #bbb; font-size: 0.75rem; text-align: center; }
  .num-col  { width: 75px; text-align: right; font-variant-numeric: tabular-nums; color: #555; }
  .tool-col code { font-size: 0.78rem; background: #f3f3f3; padding: 0.1rem 0.35rem; border-radius: 0.25rem; }
  .user-col a { color: #01696f; text-decoration: none; font-size: 0.83rem; }
  .user-col a:hover { text-decoration: underline; }

  .denied-count { color: #c62828; font-weight: 600; font-size: 0.8rem; }
  .denied-pct   { color: #e57373; font-weight: 400; font-size: 0.74rem; }
  .zero         { color: #ddd; }
  .muted        { color: #bbb; }
  .empty-row    { text-align: center; padding: 1.5rem; color: #bbb; font-size: 0.83rem; }

  /* ── Esemény feed ─────────────────────────────────────────────────── */
  .event-feed {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .event-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.85rem;
    border-bottom: 1px solid #f3f3f3;
    font-size: 0.8rem;
  }
  .event-item:last-child { border-bottom: none; }
  .event-denied { background: #fff8f8; }

  .event-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-ok   { background: #43a047; }
  .dot-deny { background: #e53935; }

  .event-body {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem 0.5rem;
    min-width: 0;
    overflow: hidden;
  }
  .event-tool code {
    font-size: 0.76rem;
    background: #f3f3f3;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    white-space: nowrap;
  }
  .event-user { color: #888; font-size: 0.76rem; }
  .event-user a { color: #01696f; text-decoration: none; }
  .event-user a:hover { text-decoration: underline; }
  .event-ts {
    font-size: 0.72rem;
    color: #bbb;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
